---
interface Stat {
  value: string
  label: string
  sub?: string
}

interface Props {
  stats: Stat[]
}

const { stats } = Astro.props
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-[var(--color-border)] rounded-xl overflow-hidden border border-[var(--color-border)]">
  {stats.map((s) => (
    <div class="bg-[var(--color-bg-card)] p-5 md:p-6">
      <div class="display text-3xl md:text-4xl font-semibold mb-1 bg-gradient-to-br from-white to-[var(--color-text-secondary)] bg-clip-text text-transparent">
        {s.value}
      </div>
      <div class="text-xs text-[var(--color-text-secondary)] uppercase tracking-wider font-medium">
        {s.label}
      </div>
      {s.sub && (
        <div class="text-[11px] text-[var(--color-text-muted)] mt-1">{s.sub}</div>
      )}
    </div>
  ))}
</div>
