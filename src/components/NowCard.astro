---
import TechChip from './TechChip.astro'
---

<div class="glass-card p-6 lg:p-7">
  {/* Live indicator header */}
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-2">
      <span class="status-dot"></span>
      <span class="eyebrow text-[var(--color-text-secondary)]">Now · Mai 2026</span>
    </div>
    <span class="text-[10px] font-mono text-[var(--color-text-muted)]">UTC+1 · Lyon</span>
  </div>

  {/* Building */}
  <div class="pb-5 border-b border-[var(--color-border)]">
    <div class="text-[11px] font-mono text-[var(--color-accent)] mb-1.5 uppercase tracking-wider">
      › Building
    </div>
    <a href="/projects/applydesk" class="group">
      <h3 class="display text-lg font-semibold tracking-tight group-hover:text-[var(--color-accent-soft)] transition-colors mb-1">
        ApplyDesk
      </h3>
      <p class="text-[13px] text-[var(--color-text-secondary)] leading-relaxed mb-3">
        Back-office personnel de recherche d'emploi — LLM, scrapers, suivi candidatures.
      </p>
      <div class="flex flex-wrap gap-1">
        <TechChip name="FastAPI" />
        <TechChip name="React" />
        <TechChip name="Gemini" />
      </div>
    </a>
  </div>

  {/* Shipped */}
  <div class="py-5 border-b border-[var(--color-border)]">
    <div class="text-[11px] font-mono text-emerald-400 mb-1.5 uppercase tracking-wider">
      ✓ Just shipped
    </div>
    <h3 class="display text-base font-semibold tracking-tight mb-0.5">
      SLAM Mapping BO <span class="text-[var(--color-text-muted)] font-normal text-xs ml-1 mono">v1.0</span>
    </h3>
    <p class="text-[13px] text-[var(--color-text-secondary)] leading-relaxed">
      Visual SLAM indoor localization · livré avril 2026.
    </p>
  </div>

  {/* Reading / learning (optional, more "alive") */}
  <div class="pt-5">
    <div class="text-[11px] font-mono text-[var(--color-text-muted)] mb-1.5 uppercase tracking-wider">
      ✱ Currently
    </div>
    <ul class="space-y-1.5 text-[13px] text-[var(--color-text-secondary)]">
      <li class="flex items-center gap-2">
        <span class="text-[var(--color-text-muted)]">→</span>
        Recherche poste senior produit
      </li>
      <li class="flex items-center gap-2">
        <span class="text-[var(--color-text-muted)]">→</span>
        Lyon / remote France
      </li>
      <li class="flex items-center gap-2">
        <span class="text-[var(--color-text-muted)]">→</span>
        Java / Python / React
      </li>
    </ul>
  </div>
</div>
