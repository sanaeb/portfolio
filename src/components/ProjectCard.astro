---
import TechChip from './TechChip.astro'

interface Props {
  title: string
  tagline: string
  stack: string[]
  href: string
  status?: 'live' | 'wip' | 'archived'
  year?: string
  featured?: boolean
  visual?: 'violet' | 'cyan' | 'amber' | 'emerald'
}

const {
  title,
  tagline,
  stack,
  href,
  status = 'wip',
  year,
  featured = false,
  visual = 'violet',
} = Astro.props

const statusStyle: Record<string, string> = {
  live: 'bg-emerald-500/15 text-emerald-300 border-emerald-500/30',
  wip: 'bg-amber-500/15 text-amber-300 border-amber-500/30',
  archived: 'bg-slate-500/15 text-slate-300 border-slate-500/30',
}

const visualGradients: Record<string, string> = {
  violet: 'from-violet-500/30 via-fuchsia-500/20 to-cyan-400/30',
  cyan: 'from-cyan-400/30 via-teal-500/20 to-emerald-400/30',
  amber: 'from-amber-400/30 via-orange-500/20 to-pink-500/30',
  emerald: 'from-emerald-400/30 via-teal-500/20 to-cyan-400/30',
}
---

<a href={href} class={`glass-card glass-card-interactive block group ${featured ? 'md:col-span-2' : ''}`}>
  {/* Visual hero strip with gradient mesh */}
  <div class={`relative h-32 md:h-40 bg-gradient-to-br ${visualGradients[visual]} overflow-hidden`}>
    <div class="absolute inset-0 bg-[var(--color-bg)]/30"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_color-mix(in_srgb,_var(--color-accent)_25%,_transparent),_transparent_60%)]"></div>
    {/* Decorative grid pattern */}
    <svg
      class="absolute inset-0 w-full h-full opacity-[0.08]"
      aria-hidden="true"
    >
      <defs>
        <pattern id={`grid-${title}`} width="24" height="24" patternUnits="userSpaceOnUse">
          <path d="M 24 0 L 0 0 0 24" fill="none" stroke="currentColor" stroke-width="0.5"></path>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill={`url(#grid-${title})`}></rect>
    </svg>
    {/* Title overlay */}
    <div class="absolute inset-x-0 bottom-0 p-5 md:p-6 flex items-end justify-between gap-4">
      <h3 class="display text-2xl md:text-3xl font-semibold tracking-tight text-white">
        {title}
      </h3>
      <span class={`text-[10px] font-mono uppercase tracking-wider px-2 py-1 rounded border ${statusStyle[status]}`}>
        {status === 'wip' ? 'WIP' : status}{year && ` · ${year}`}
      </span>
    </div>
  </div>

  <div class="p-5 md:p-6">
    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">{tagline}</p>
    <div class="flex flex-wrap gap-1.5 mb-4">
      {stack.map((s) => <TechChip name={s} />)}
    </div>
    <div class="text-xs text-[var(--color-text-muted)] group-hover:text-[var(--color-accent-soft)] transition-colors inline-flex items-center gap-1.5">
      Voir le projet <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
    </div>
  </div>
</a>
