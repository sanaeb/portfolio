---
interface Props {
  number: string
  title: string
  body: string
  icon: 'backend' | 'product' | 'research'
}

const { number, title, body, icon } = Astro.props
---

<div class="glass-card glass-card-interactive p-6 md:p-7 group">
  <div class="flex items-start justify-between mb-5">
    <div class="eyebrow text-[var(--color-accent)]">{number}</div>
    <div class="text-[var(--color-text-muted)] group-hover:text-[var(--color-accent-soft)] transition-colors">
      {icon === 'backend' && (
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
          <path d="M3 5v6c0 1.66 4.03 3 9 3s9-1.34 9-3V5"></path>
          <path d="M3 11v6c0 1.66 4.03 3 9 3s9-1.34 9-3v-6"></path>
        </svg>
      )}
      {icon === 'product' && (
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
          <line x1="12" y1="22.08" x2="12" y2="12"></line>
        </svg>
      )}
      {icon === 'research' && (
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M21 21l-4.35-4.35"></path>
          <path d="M11 8v6M8 11h6" stroke-linecap="round"></path>
        </svg>
      )}
    </div>
  </div>
  <h3 class="display text-lg font-semibold tracking-tight mb-3">{title}</h3>
  <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{body}</p>
</div>
