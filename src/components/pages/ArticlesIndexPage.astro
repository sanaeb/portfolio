---
import Layout from '../../layouts/Layout.astro'
import SectionHeader from '../SectionHeader.astro'
import { getDict, type Lang } from '../../i18n/translations'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = getDict(lang)
const prefix = lang === 'fr' ? '' : '/en'
---

<Layout lang={lang} title={t.meta.articlesTitle} description={t.meta.articlesDescription}>
  <section class="pt-12 md:pt-20 pb-12">
    <div class="max-w-6xl mx-auto">
      <SectionHeader
        eyebrow={t.articles.eyebrow}
        title={t.articles.title}
        description={t.articles.description}
      />
    </div>
  </section>

  <section class="pb-16 md:pb-20">
    <div class="max-w-4xl mx-auto grid gap-4">
      {t.articles.technical.map((a) => (
        <a
          href={`${prefix}/articles/${a.slug}`}
          class="glass-card glass-card-interactive p-6 md:p-8 flex flex-col gap-3"
        >
          <div class="flex items-center gap-3 flex-wrap">
            <span class="text-[11px] font-mono uppercase tracking-wider text-[var(--color-accent)]">
              {a.category}
            </span>
            <span class="text-[11px] text-[var(--color-text-muted)] mono">{a.date} · {a.readTime}</span>
          </div>
          <h2 class="display text-xl md:text-2xl font-semibold tracking-tight text-balance">
            {a.title}
          </h2>
          <p class="text-sm md:text-base text-[var(--color-text-secondary)] leading-relaxed text-pretty">
            {a.lede}
          </p>
          <div class="text-xs text-[var(--color-text-muted)] mt-2 inline-flex items-center gap-1.5">
            {t.articles.readMore} <span aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section id="publications" class="pb-20 md:pb-28">
    <div class="max-w-4xl mx-auto">
      <SectionHeader
        eyebrow={t.articles.papers.eyebrow}
        title={t.articles.papers.title}
        description={t.articles.papers.description}
      />
      <div class="grid gap-4">
        {t.articles.papers.items.map((p) => (
          <a
            href={`${prefix}/articles/${p.slug}`}
            class="glass-card glass-card-interactive p-6 md:p-8 flex flex-col gap-3"
          >
            <div class="flex items-baseline gap-3">
              <span class="text-[11px] font-mono uppercase tracking-wider text-[var(--color-accent)]">
                {p.venue}
              </span>
              <span class="text-[11px] text-[var(--color-text-muted)] mono">{p.year}</span>
            </div>
            <h3 class="display text-base md:text-xl font-semibold tracking-tight leading-snug text-balance">
              {p.title}
            </h3>
            <p class="text-sm md:text-base text-[var(--color-text-secondary)] leading-relaxed text-pretty">
              {p.summary}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {p.keywords.map((k) => (
                <span class="text-[10px] font-mono px-2 py-0.5 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] bg-[var(--color-bg-card)]">
                  {k}
                </span>
              ))}
            </div>
            <div class="text-xs text-[var(--color-text-muted)] mt-1 inline-flex items-center gap-1.5">
              {t.articles.readMore} <span aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
