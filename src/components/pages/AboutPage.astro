---
import Layout from '../../layouts/Layout.astro'
import Avatar from '../Avatar.astro'
import SectionHeader from '../SectionHeader.astro'
import { getDict, siteConfig, type Lang } from '../../i18n/translations'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = getDict(lang)
const prefix = lang === 'fr' ? '' : '/en'
const projectsHref = `${prefix}/projects`

const paperSlugs: Record<string, string> = {
  'IEEE IPAS-2020': 'cnn-colorization-improving',
  'IEEE MCNA-2020': 'cnn-colorization-palette',
  'EUVIP-2019': 'handwriting-anomaly-detection',
  'EUVIP-2018': 'face-recognition-visible-nir',
}
---

<Layout lang={lang} title={t.meta.aboutTitle}>
  {/* ===== HERO ===== */}
  <section class="pt-12 md:pt-20 pb-12">
    <div class="max-w-4xl mx-auto">
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <div class="shrink-0">
          <Avatar
            initials="SB"
            size="xl"
            gradient="violet"
            src={siteConfig.photo}
            alt="Sanae Boutarfass"
          />
        </div>
        <div>
          <div class="eyebrow mb-3">{t.about.eyebrow}</div>
          <h1 class="display text-4xl md:text-5xl font-semibold tracking-tight mb-4 text-balance">
            {t.about.title}
          </h1>
          <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed text-pretty">
            {t.about.subtitle}
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ===== JOURNEY ===== */}
  <section class="pb-16 md:pb-20">
    <div class="max-w-4xl mx-auto">
      <SectionHeader eyebrow={t.about.journey.eyebrow} title={t.about.journey.title} />
      <div class="max-w-3xl space-y-6 text-base md:text-lg leading-relaxed">
        <p>
          {t.about.journey.p1Before}<span class="text-[var(--color-text)] font-medium">{t.about.journey.p1Highlight}</span>{t.about.journey.p1After}
        </p>
        <p>{t.about.journey.p2}</p>
      </div>
    </div>
  </section>

  {/* ===== TODAY ===== */}
  <section class="pb-16 md:pb-20">
    <div class="max-w-4xl mx-auto">
      <SectionHeader eyebrow={t.about.today.eyebrow} title={t.about.today.title} />
      <div class="max-w-3xl space-y-6 text-base md:text-lg leading-relaxed">
        <p>
          {t.about.today.p1Before}<a
            href="https://www.okeenea.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="link-underline"
          >{t.about.today.p1LinkLabel}</a>{t.about.today.p1Middle}<span class="text-[var(--color-text)] font-medium">{t.about.today.p1Highlight}</span>{t.about.today.p1After}
        </p>
        <p>
          {t.about.today.p2Before}<span class="text-[var(--color-text)] font-medium">{t.about.today.p2Highlight1}</span>{t.about.today.p2Middle}<span class="text-[var(--color-text)] font-medium">{t.about.today.p2Highlight2}</span>{t.about.today.p2After}
        </p>
      </div>
    </div>
  </section>

  {/* ===== CODE ===== */}
  <section class="pb-16 md:pb-20">
    <div class="max-w-4xl mx-auto">
      <SectionHeader eyebrow={t.about.code.eyebrow} title={t.about.code.title} />
      <div class="max-w-3xl space-y-6 text-base md:text-lg leading-relaxed">
        <p>{t.about.code.p1}</p>
        <p>
          {t.about.code.p2Before}<a href={projectsHref} class="link-underline">{t.about.code.p2Link}</a>{t.about.code.p2After}
        </p>
      </div>
    </div>
  </section>

  {/* ===== OFF-SCREEN ===== */}
  <section class="pb-16 md:pb-20">
    <div class="max-w-4xl mx-auto">
      <SectionHeader eyebrow={t.about.offscreen.eyebrow} title={t.about.offscreen.title} />
      <div class="max-w-3xl space-y-6 text-base md:text-lg leading-relaxed">
        <p>
          {t.about.offscreen.p1Before}<span class="text-[var(--color-text)] font-medium">{t.about.offscreen.p1Highlight}</span>{t.about.offscreen.p1After}
        </p>
      </div>
    </div>
  </section>

  {/* ===== FORMATION ===== */}
  <section class="pb-16 md:pb-20">
    <div class="max-w-4xl mx-auto">
      <SectionHeader eyebrow={t.about.formation.eyebrow} title={t.about.formation.title} />
      <div class="glass-card divide-y divide-[var(--color-border)]">
        {t.about.formation.items.map((f) => (
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 p-5 md:p-6">
            <div>
              <div class="text-[var(--color-text)] font-medium">{f.degree}</div>
              <div class="text-sm text-[var(--color-text-secondary)] mt-0.5">
                {f.institution} · <span class="italic">{f.specialty}</span>
              </div>
            </div>
            <div class="mono text-xs text-[var(--color-text-muted)] shrink-0">{f.period}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ===== PUBLICATIONS ===== */}
  <section class="pb-20 md:pb-28">
    <div class="max-w-4xl mx-auto">
      <SectionHeader
        eyebrow={t.about.publications.eyebrow}
        title={t.about.publications.title}
        description={t.about.publications.description}
      />
      <div class="grid md:grid-cols-2 gap-3">
        {t.about.publications.items.map((p) => {
          const slug = paperSlugs[`${p.venue}-${p.year}`]
          const cardClass = slug
            ? 'glass-card glass-card-interactive p-5 group'
            : 'glass-card p-5'
          const content = (
            <>
              <div class="flex items-baseline justify-between gap-3 mb-2">
                <span class="text-[11px] font-mono uppercase tracking-wider text-[var(--color-accent)]">
                  {p.venue}
                </span>
                <span class="text-xs text-[var(--color-text-muted)] mono">{p.year}</span>
              </div>
              <h3 class="text-sm md:text-base font-medium leading-snug">{p.title}</h3>
              {slug && (
                <div class="text-[11px] text-[var(--color-text-muted)] mt-3 inline-flex items-center gap-1.5 group-hover:text-[var(--color-accent-soft)] transition-colors">
                  {lang === 'fr' ? 'Lire le résumé' : 'Read summary'} <span aria-hidden="true">→</span>
                </div>
              )}
            </>
          )
          return slug ? (
            <a href={`${prefix}/articles/${slug}`} class={cardClass}>{content}</a>
          ) : (
            <div class={cardClass}>{content}</div>
          )
        })}
      </div>
    </div>
  </section>
</Layout>
