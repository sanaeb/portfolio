---
interface Props {
  eyebrow?: string
  title: string
  description?: string
  cta?: { href: string; label: string }
}

const { eyebrow, title, description, cta } = Astro.props
---

<div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8 md:mb-12">
  <div>
    {eyebrow && <div class="eyebrow mb-3">{eyebrow}</div>}
    <h2 class="display text-2xl md:text-3xl font-semibold tracking-tight">{title}</h2>
    {description && (
      <p class="text-[var(--color-text-secondary)] mt-2 max-w-2xl text-sm md:text-base leading-relaxed">{description}</p>
    )}
  </div>
  {cta && (
    <a href={cta.href} class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent-soft)] transition-colors inline-flex items-center gap-1.5 shrink-0">
      {cta.label}
      <span aria-hidden="true">→</span>
    </a>
  )}
</div>
