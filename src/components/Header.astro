---
import LangSwitcher from './LangSwitcher.astro'
import { getDict, siteConfig, type Lang } from '../i18n/translations'

interface Props {
  lang: Lang
}
const { lang } = Astro.props
const t = getDict(lang)

const homeHref = lang === 'fr' ? '/' : '/en/'
const prefix = lang === 'fr' ? '' : '/en'

const path = Astro.url.pathname.replace(/\/$/, '') || '/'

const nav = [
  { href: homeHref, label: t.nav.home },
  { href: `${prefix}/experience`, label: t.nav.experience },
  { href: `${prefix}/projects`, label: t.nav.projects },
  { href: `${prefix}/articles`, label: t.nav.articles },
  { href: `${prefix}/about`, label: t.nav.about },
]

function isActive(href: string) {
  const cleanHref = href.replace(/\/$/, '') || '/'
  if (cleanHref === '/' || cleanHref === '/en') return path === '/' || path === '/en'
  return path === cleanHref || path.startsWith(cleanHref + '/')
}

const cvHref = siteConfig.cvPath[lang]
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/70 backdrop-blur-xl supports-[backdrop-filter]:bg-[var(--color-bg)]/50">
  <div class="max-w-6xl mx-auto px-6 md:px-8 h-16 flex items-center justify-between gap-4">
    <a href={homeHref} class="flex items-center gap-2.5 group shrink-0" aria-label="Sanae Boutarfass — Home">
      <span class="relative inline-flex h-8 w-8 items-center justify-center rounded-lg overflow-hidden">
        <span class="absolute inset-0 bg-gradient-to-br from-violet-500 via-fuchsia-500 to-cyan-400"></span>
        <span class="absolute inset-[1px] rounded-[7px] bg-[var(--color-bg)]"></span>
        <span class="relative text-[12px] font-semibold tracking-tight text-white">SB</span>
      </span>
      <span class="hidden sm:flex items-baseline gap-2">
        <span class="text-sm font-semibold tracking-tight">Sanae Boutarfass</span>
      </span>
    </a>

    {/* Desktop nav */}
    <div class="hidden md:flex items-center gap-3">
      <nav class="flex items-center gap-1 text-sm">
        {nav.map((item) => {
          const active = isActive(item.href)
          return (
            <a
              href={item.href}
              class:list={[
                'relative px-3 py-1.5 rounded-md transition-colors duration-150',
                active
                  ? 'text-[var(--color-text)]'
                  : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text)]',
              ]}
            >
              {item.label}
              {active && (
                <span
                  class="absolute inset-x-2 -bottom-px h-px bg-gradient-to-r from-transparent via-[var(--color-accent)] to-transparent"
                  aria-hidden="true"
                ></span>
              )}
            </a>
          )
        })}
      </nav>

      <span class="w-px h-5 bg-[var(--color-border)]"></span>

      {/* GitHub icon */}
      <a
        href={siteConfig.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t.actions.github}
        title={t.actions.github}
        class="inline-flex h-8 w-8 items-center justify-center rounded-md text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-elev)] transition-colors"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>

      {/* Download CV button */}
      <a
        href={cvHref}
        download
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-medium border border-[var(--color-border-strong)] bg-[var(--color-bg-card)] text-[var(--color-text)] hover:border-[var(--color-accent)]/60 hover:bg-[var(--color-bg-elev)] transition-colors"
        title={t.actions.downloadCv}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {t.actions.downloadCvShort}
      </a>

      <span class="w-px h-5 bg-[var(--color-border)]"></span>

      <LangSwitcher lang={lang} currentPath={path} />
    </div>

    {/* Mobile : hamburger */}
    <details class="md:hidden relative" id="mobile-menu">
      <summary
        class="list-none flex items-center justify-center h-9 w-9 rounded-md text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-elev)] transition-colors cursor-pointer"
        aria-label="Open menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" class="line-top transition-transform"/>
          <line x1="3" y1="12" x2="21" y2="12" class="line-mid transition-opacity"/>
          <line x1="3" y1="18" x2="21" y2="18" class="line-bot transition-transform"/>
        </svg>
      </summary>
      <div class="absolute right-0 top-12 w-72 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] shadow-2xl overflow-hidden">
        <nav class="flex flex-col">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'px-5 py-3 border-b border-[var(--color-border)] last:border-0 transition-colors',
                isActive(item.href)
                  ? 'bg-[var(--color-bg-elev)] text-[var(--color-text)]'
                  : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-elev)] hover:text-[var(--color-text)]',
              ]}
            >
              {item.label}
            </a>
          ))}
          <div class="px-5 py-4 border-t border-[var(--color-border)] flex items-center gap-3">
            <a
              href={siteConfig.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-text)]"
              >GitHub</a>
            <span class="text-[var(--color-text-muted)]">·</span>
            <a
              href={cvHref}
              download
              class="text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-text)]"
              >CV</a>
            <span class="text-[var(--color-text-muted)] ml-auto"></span>
            <LangSwitcher lang={lang} currentPath={path} />
          </div>
        </nav>
      </div>
    </details>
  </div>
</header>

<style>
  /* Hide the default details marker */
  #mobile-menu > summary::-webkit-details-marker { display: none; }
  #mobile-menu > summary::marker { content: ''; }

  /* Animate hamburger → X */
  #mobile-menu[open] .line-top { transform: translateY(6px) rotate(45deg); transform-origin: center; }
  #mobile-menu[open] .line-mid { opacity: 0; }
  #mobile-menu[open] .line-bot { transform: translateY(-6px) rotate(-45deg); transform-origin: center; }
</style>
