---
interface Props {
  initials?: string
  size?: 'sm' | 'md' | 'lg' | 'xl'
  gradient?: 'violet' | 'cyan' | 'amber' | 'emerald' | 'slate'
  /** Optional photo URL. When provided, renders the photo inside the gradient frame. */
  src?: string
  alt?: string
}

const {
  initials = 'SB',
  size = 'md',
  gradient = 'violet',
  src,
  alt = 'Photo de profil',
} = Astro.props

const sizes = {
  sm: 'h-9 w-9 text-[12px]',
  md: 'h-12 w-12 text-sm',
  lg: 'h-20 w-20 text-xl',
  xl: 'h-32 w-32 text-3xl md:h-40 md:w-40 md:text-4xl',
}

const gradients = {
  violet: 'from-violet-500 via-fuchsia-500 to-cyan-400',
  cyan: 'from-cyan-400 via-teal-400 to-emerald-400',
  amber: 'from-amber-400 via-orange-500 to-pink-500',
  emerald: 'from-emerald-400 via-teal-500 to-cyan-500',
  slate: 'from-slate-500 via-slate-600 to-slate-700',
}
---

<span class={`relative inline-flex items-center justify-center rounded-2xl overflow-hidden ${sizes[size]}`}>
  <span class={`absolute inset-0 bg-gradient-to-br ${gradients[gradient]} opacity-90`}></span>
  <span class="absolute inset-[2px] rounded-[14px] bg-[var(--color-bg-card)] overflow-hidden">
    {src ? (
      <img
        src={src}
        alt={alt}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover"
      />
    ) : (
      <span class="w-full h-full flex items-center justify-center font-semibold tracking-tight text-[var(--color-text)]">
        {initials}
      </span>
    )}
  </span>
</span>
