---
import Layout from '../layouts/Layout.astro'
---

<Layout lang="fr" title="404 — Sanae Boutarfass">
  <section class="pt-20 md:pt-32 pb-20 md:pb-32">
    <div class="max-w-3xl mx-auto text-center">
      <div class="eyebrow mb-6 text-[var(--color-accent)]">Erreur 404</div>
      <h1 class="display text-7xl md:text-9xl font-bold tracking-tighter mb-6 bg-gradient-to-br from-white via-[var(--color-accent-soft)] to-[var(--color-accent-2)] bg-clip-text text-transparent">
        404
      </h1>
      <p class="text-lg md:text-xl text-[var(--color-text-secondary)] leading-relaxed mb-10 max-w-xl mx-auto">
        Cette page n'existe pas — ou n'existe plus.
        Pas de panique, je n'ai rien cassé en prod.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="btn btn-primary">
          Retour à l'accueil
          <span aria-hidden="true">→</span>
        </a>
        <a href="/projects" class="btn btn-secondary">
          Voir mes projets
        </a>
      </div>
    </div>
  </section>
</Layout>
